# Copy this file to .env and fill in keys. Sources without a key are skipped at runtime.

# Ticketmaster Discovery API — free, no card required.
# Sign up: https://developer-acct.ticketmaster.com/user/register
TICKETMASTER_API_KEY=

# SeatGeek Platform API — free, register an app.
# Sign up: https://seatgeek.com/account/develop
SEATGEEK_CLIENT_ID=

# NYC Open Data (Socrata) app token — optional but raises rate limits.
# Sign up: https://data.cityofnewyork.us/profile/app_tokens
NYC_OPEN_DATA_APP_TOKEN=

# Eventbrite — public search API was deprecated in 2020. Token here only works
# for your own org's events. Left here for future use.
EVENTBRITE_OAUTH_TOKEN=

# PredictHQ — paid, optional. https://www.predicthq.com/
PREDICTHQ_API_KEY=

# Bandsintown — partner access required for the events endpoint.
BANDSINTOWN_APP_ID=

# Yelp Fusion API — free, no card required. Best source for community events
# (singles nights, fitness classes, bar events, food tastings, kids activities).
# Sign up: https://www.yelp.com/developers → Create App → copy API Key
YELP_API_KEY=
